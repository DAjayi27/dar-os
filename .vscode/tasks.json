{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-and-debug-qemu",
      "type": "shell",
      "command": "cargo run -- -s -S",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Compiling.*$",
          "endsPattern": "^.*Finished.*$"
        }
      }
    }
  ]
}